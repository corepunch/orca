<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE Screen SYSTEM "https://corepunch.github.io/orca/schemas/orca.dtd">
<Screen Name="Application" Width="1280" Height="800" ClearColor="$surface" StyleSheet="Example/Styles/app.css">
	<Grid Name="Root" Rows="64px auto" class="app-shell">
		<StackView Name="NavBar" class="panel navbar">
			<StackView Name="BrandMark" class="brand-mark">
				<ImageView Name="BrandIcon" class="brand-icon" Source="Example/Icons/blocks.svg?width=22&amp;type=mask"/>
				<TextBlock Name="Brand" class="brand-text">ORCA</TextBlock>
			</StackView>
			<TextBlock Name="NavOverview" class="nav-link">Overview</TextBlock>
			<TextBlock Name="NavFeatures" class="nav-link">Features</TextBlock>
			<TextBlock Name="NavGallery" class="nav-link">Gallery</TextBlock>
			<TextBlock Name="NavDocs" class="nav-link">Docs</TextBlock>
		</StackView>
		<StackView Name="Body" class="app-body">
			<BindingExpression Target="Node.HorizontalPadding">IF(STEP(640, {Screen.Width}), Vector2(40,40), Vector2(8,8))</BindingExpression>
			<Grid Name="Hero" Columns="auto auto" class="hero">
				<StackView Name="HeroContent" class="hero-content">
					<TextBlock Name="HeadlineLine1" class="hero-title">Build stunning</TextBlock>
					<TextBlock Name="HeadlineLine2" class="hero-title-accent">UI in real-time.</TextBlock>
					<Node2D Name="HeadlineSpacer" class="headline-spacer"/>
					<TextBlock Name="SubHeadline" class="hero-subtitle">A modern UI engine for games and native apps. Compose layouts from grids, stacks, text, and images — all rendered at 60 fps.</TextBlock>
					<Node2D Name="MetricSpacer" class="metric-spacer"/>
					<GridBox Name="Metrics" Columns="auto auto auto" class="grid"
						ItemsSource="Example/Data/ApplicationData:Metrics"
						ItemTemplate="Example/Prefabs/Mertic"/>
				</StackView>
				<ImageView Name="HeroImage" Source="Example/Images/people" Stretch="UniformToFill"/>
				<BindingExpression Target="Node.Visible">STEP(640, {Screen.Width})</BindingExpression>
				<BindingExpression Target="Grid.Columns">IF(STEP(640, {Screen.Width}), "auto auto", "auto")</BindingExpression>
			</Grid>
			<StackView Name="TabbedTechSection" class="section surface-section">
				<BindingExpression Target="Node.HorizontalPadding">IF(STEP(640, {Screen.Width}), Vector2(40,40), Vector2(8,8))</BindingExpression>
				<TextBlock Name="TabbedTechHeading" class="section-heading" Text="Build the UI, not the ceremony"/>
				<TextBlock Name="TabbedTechSubheading" class="section-copy"
					Text="A clean XML surface, Lua where things move, MoonScript when the app grows, and one UI that can travel across targets."/>
				<GridBox Name="OrcaSignals" Columns="auto auto auto" class="grid"
					ItemsSource="Example/Data/ApplicationData:Signals"
					ItemTemplate="Example/Prefabs/SignalCard">
					<BindingExpression Target="Grid.Columns">IF(STEP(640, {Screen.Width}), "auto auto auto", "auto auto")</BindingExpression>
				</GridBox>
				<TabView Name="OrcaTabs" SelectedValue="xml">
					<TabBar Name="OrcaTabBar" class="panel tabbar">
						<Tab Name="XmlTab" Value="xml" class="tab">XML</Tab>
						<Tab Name="LuaTab" Value="lua" class="tab">Lua</Tab>
						<Tab Name="MoonTab" Value="moon" class="tab">MoonScript</Tab>
						<Tab Name="DeployTab" Value="deploy" class="tab">Deploy</Tab>
					</TabBar>
					<StackView Name="xml" class="tab-panel">
						<LayerPrefabPlaceholder Name="XmlPanelHeader" PlaceholderTemplate="Example/Prefabs/TabPanelHeader"
							DataContextSource="Example/Data/ApplicationData:XmlPanelHeader"/>
						<Grid Name="XmlGrid" Columns="auto auto" class="grid">
							<StackView Name="XmlCopy" class="copy-stack">
								<TextBlock Name="XmlBody" class="section-copy"
									Text="The screen stays legible at a glance, which makes it easy to scan, compare, and reshape as the design evolves."/>
								<StackView Name="XmlNotes" class="panel note-panel">
									<TextBlock Name="XmlNote1" class="note-text" Text="• Grids and stacks stay visible in the source."/>
									<TextBlock Name="XmlNote2" class="note-text" Text="• Spacing, padding, and hierarchy remain explicit."/>
									<TextBlock Name="XmlNote3" class="note-text" Text="• The shape of the screen is easy to read before it ever runs."/>
								</StackView>
							</StackView>
							<StackView Name="XmlModel" class="card stack-card model-panel">
								<TextBlock Name="XmlModelHeading" class="card-title" Text="The structure stays honest"/>
								<GridBox Name="XmlModelGrid" Columns="auto"
									ItemsSource="Example/Data/ApplicationData:XmlModel"
									ItemTemplate="Example/Prefabs/XmlModelNode"/>
							</StackView>
						</Grid>
					</StackView>
					<StackView Name="lua" class="tab-panel">
						<LayerPrefabPlaceholder Name="LuaPanelHeader" PlaceholderTemplate="Example/Prefabs/TabPanelHeader"
							DataContextSource="Example/Data/ApplicationData:LuaPanelHeader"/>
						<TextBlock Name="LuaBody" class="section-copy"
							Text="The parts that move stay beside the screen that uses them, so interaction and state feel close and easy to change."/>
						<GridBox Name="LuaGrid" Columns="auto auto auto" class="grid"
							ItemsSource="Example/Data/ApplicationData:LuaCards"
							ItemTemplate="Example/Prefabs/IconCard"/>
					</StackView>
					<StackView Name="moon" class="tab-panel">
						<LayerPrefabPlaceholder Name="MoonPanelHeader" PlaceholderTemplate="Example/Prefabs/TabPanelHeader"
							DataContextSource="Example/Data/ApplicationData:MoonPanelHeader"/>
						<Grid Name="MoonGrid" Columns="auto auto" class="grid">
							<StackView Name="MoonCopy" class="copy-stack">
								<TextBlock Name="MoonBody" class="section-copy"
									Text="MoonScript keeps larger app code compact and expressive, while still compiling to the same Lua runtime."/>
								<StackView Name="MoonNotes" class="panel note-panel">
									<TextBlock Name="MoonNote1" class="note-text" Text="• Helpful when app modules get a little larger."/>
									<TextBlock Name="MoonNote2" class="note-text" Text="• The syntax stays concise, but the runtime stays Lua."/>
									<TextBlock Name="MoonNote3" class="note-text" Text="• It pairs naturally with XML screens and Lua helpers."/>
								</StackView>
							</StackView>
							<StackView Name="MoonModel" class="card stack-card model-panel">
								<TextBlock Name="MoonModelHeading" class="card-title" Text="Same runtime, less ceremony"/>
								<TextBlock Name="MoonModelLine1" class="moon-model-line" Text="Cleaner class bodies"/>
								<TextBlock Name="MoonModelLine2" class="moon-model-line" Text="Readable app controllers"/>
								<TextBlock Name="MoonModelLine3" class="moon-model-line" Text="Plain Lua at runtime"/>
								<TextBlock Name="MoonModelLine4" class="moon-model-line" Text="Comfortable beside XML layouts"/>
							</StackView>
						</Grid>
					</StackView>
					<StackView Name="deploy" class="tab-panel">
						<LayerPrefabPlaceholder Name="DeployPanelHeader" PlaceholderTemplate="Example/Prefabs/TabPanelHeader"
							DataContextSource="Example/Data/ApplicationData:DeployPanelHeader"/>
						<TextBlock Name="DeployBody" class="section-copy"
							Text="Build once, tune the spacing, and carry the same design language across desktop, mobile, and web-oriented targets."/>
						<GridBox Name="DeployGrid" Columns="auto auto auto" class="grid"
							ItemsSource="Example/Data/ApplicationData:DeployCards"
							ItemTemplate="Example/Prefabs/IconCard"/>
						<GridBox Name="DeployImages" Columns="auto auto" class="grid"
							ItemsSource="Example/Data/ApplicationData:DeployImages"
							ItemTemplate="Example/Prefabs/ImageCaptionCard"/>
						<StackView Name="DeployCommandLink" class="panel command-link">
							<ImageView Name="DeployCommandIcon" class="command-icon" Source="Example/Icons/monitor.svg?width=20&amp;type=mask"/>
							<StackView Name="DeployCommandCopy" class="command-copy">
								<TextBlock Name="DeployCommandLabel" class="command-label" Text="Desktop build"/>
								<TextBlock Name="DeployCommandValue" class="command-value" Text="make clean &amp;&amp; make -j8 &amp;&amp; build/bin/orca samples/Example"/>
							</StackView>
						</StackView>
					</StackView>
				</TabView>
			</StackView>
			<GridBox Name="FeatureSection" Columns="auto auto auto auto" class="grid feature-section"
				ItemsSource="Example/Data/ApplicationData:FeatureCards"
				ItemTemplate="Example/Prefabs/FeatureImageCard"/>
			<StackView Name="GallerySection" class="section surface-section gallery-section">
				<BindingExpression Target="Node.HorizontalPadding">IF(STEP(640, {Screen.Width}), Vector2(40,40), Vector2(8,8))</BindingExpression>
				<TextBlock Name="GalleryHeading" class="section-heading" Text="Gallery"/>
				<TextBlock Name="GallerySubheading" class="section-copy"
					Text="Screenshots and scenes rendered entirely by the ORCA engine."/>
				<GridBox Name="GalleryGrid" Columns="auto auto auto" Spacing="16"
					ItemsSource="Example/Data/ApplicationData:GalleryCards"
					ItemTemplate="Example/Prefabs/GalleryCard"/>
			</StackView>
			<StackView Name="WorkflowSection" class="section deep-section workflow-section">
				<BindingExpression Target="Node.HorizontalPadding">IF(STEP(640, {Screen.Width}), Vector2(40,40), Vector2(8,8))</BindingExpression>
				<TextBlock Name="WorkflowHeading" class="section-heading" Text="How It Works"/>
				<TextBlock Name="WorkflowSubheading" class="section-copy"
					Text="From XML layout to a live rendered scene in four simple steps."/>
				<GridBox Name="WorkflowSteps" Columns="auto auto auto auto" class="grid"
					ItemsSource="Example/Data/ApplicationData:WorkflowSteps"
					ItemTemplate="Example/Prefabs/WorkflowStep">
					<BindingExpression Target="Grid.Columns">IF(STEP(640, {Screen.Width}), "auto auto auto auto", "auto auto")</BindingExpression>
				</GridBox>
			</StackView>
			<StackView Name="TestimonialsSection" class="section surface-section testimonials-section">
				<BindingExpression Target="Node.HorizontalPadding">IF(STEP(640, {Screen.Width}), Vector2(40,40), Vector2(8,8))</BindingExpression>
				<TextBlock Name="TestimonialsHeading" class="section-heading" Text="What Developers Say"/>
				<GridBox Name="TestimonialsGrid" Columns="auto auto auto" class="grid"
					ItemsSource="Example/Data/ApplicationData:Quotes"
					ItemTemplate="Example/Prefabs/Quote"/>
			</StackView>
			<StackView Name="CtaSection" class="section panel cta-section">
				<BindingExpression Target="Node.HorizontalPadding">IF(STEP(640, {Screen.Width}), Vector2(60,60), Vector2(16,16))</BindingExpression>
				<TextBlock Name="CtaHeading" class="cta-heading" Text="Ready to build something great?"/>
				<TextBlock Name="CtaBody" class="cta-body"
					Text="Download ORCA, open a sample project, and have your first screen running in minutes."/>
				<StackView Name="CtaButtons" class="cta-button-row">
					<TextBlock Name="CtaButtonPrimary" class="button cta-button primary-button" Text="Get Started"
						LeftButtonUp="{Screen.ShowModal Path=Example/Screens/GetStartedPopup}"/>
					<TextBlock Name="CtaButtonSecondary" class="button cta-button secondary-button" Text="Learn more"/>
				</StackView>
			</StackView>
		</StackView>
	</Grid>
</Screen>
