<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE Screen SYSTEM "https://corepunch.github.io/orca/schemas/orca.dtd">
<Screen Name="Application" Width="1280" Height="800" ClearColor="#0B0B12">
	<Grid Name="Root" Rows="64px auto" Spacing="0">
		<StackView Name="NavBar" BackgroundColor="#1A1A28" Direction="Horizontal" Spacing="32" AlignItems="Center" HorizontalPadding="40">
			<TextBlock Name="Brand" Text="ORCA" FontSize="20" ForegroundColor="#8B5CF6" Width="72"/>
			<TextBlock Name="NavOverview" Text="Overview" FontSize="14" ForegroundColor="#94A3B8"/>
			<TextBlock Name="NavFeatures" Text="Features" FontSize="14" ForegroundColor="#94A3B8"/>
			<TextBlock Name="NavGallery" Text="Gallery" FontSize="14" ForegroundColor="#94A3B8"/>
			<TextBlock Name="NavDocs" Text="Docs" FontSize="14" ForegroundColor="#94A3B8"/>
		</StackView>
		<StackView Name="Body" Direction="Vertical" Spacing="40" OverflowY="Scroll" ClipChildren="true" Padding="40" BackgroundColor="#09090F">
			<Node.HorizontalPadding>IF(STEP(640, {../../Node.ActualWidth}), Vector2(40,40), Vector2(8,8))</Node.HorizontalPadding>
			<Grid Name="Hero" Columns="auto auto" Spacing="24" BackgroundColor="#0B0B12">
				<StackView Name="HeroContent" Direction="Vertical" Spacing="0" Padding="16">
					<TextBlock Name="HeadlineLine1" Text="Build stunning" FontSize="48" ForegroundColor="#F1F5F9"/>
					<TextBlock Name="HeadlineLine2" Text="UI in real-time." FontSize="48" ForegroundColor="#8B5CF6"/>
					<Node2D Name="HeadlineSpacer" Height="20"/>
					<TextBlock Name="SubHeadline"
						Text="A modern UI engine for games and native apps. Compose layouts from grids, stacks, text, and images — all rendered at 60 fps."
						FontSize="15"
						ForegroundColor="#64748B"
						WordWrap="true"/>
					<Node2D Name="MetricSpacer" Height="40"/>
					<Grid Name="Metrics" Columns="auto auto auto" Spacing="16">
						<StackView Name="MetricUsers" Direction="Vertical" Spacing="4" BackgroundColor="#1A1A28" Padding="20" Width="120">
							<TextBlock Name="MetricUsersValue" Text="2.4 M" FontSize="28" ForegroundColor="#8B5CF6"/>
							<TextBlock Name="MetricUsersLabel" Text="Active users" FontSize="11" ForegroundColor="#4B5563"/>
						</StackView>
						<StackView Name="MetricUptime" Direction="Vertical" Spacing="4" BackgroundColor="#1A1A28" Padding="20" Width="120">
							<TextBlock Name="MetricUptimeValue" Text="99.9 %" FontSize="28" ForegroundColor="#10B981"/>
							<TextBlock Name="MetricUptimeLabel" Text="Uptime SLA" FontSize="11" ForegroundColor="#4B5563"/>
						</StackView>
						<StackView Name="MetricFrame" Direction="Vertical" Spacing="4" BackgroundColor="#1A1A28" Padding="20" Width="120">
							<TextBlock Name="MetricFrameValue" Text="1.2 ms" FontSize="28" ForegroundColor="#3B82F6"/>
							<TextBlock Name="MetricFrameLabel" Text="Frame time" FontSize="11" ForegroundColor="#4B5563"/>
						</StackView>
					</Grid>
				</StackView>
				<ImageView Name="HeroImage" Image="Example/Images/people" Stretch="UniformToFill">
					<Node.Visible>STEP(640, {../../../Node.ActualWidth})</Node.Visible>
				</ImageView>
				<Grid.Columns>IF(STEP(640, {../../../Node.ActualWidth}), "auto auto", "auto")</Grid.Columns>
			</Grid>
			<Grid Name="FeatureSection" Columns="auto auto auto" Spacing="20">
				<StackView Name="CardText" Direction="Vertical" Spacing="10" BackgroundColor="#141420" Padding="28">
					<TextBlock Name="CardTextIcon" Text="Aa" FontSize="20" ForegroundColor="#8B5CF6" BackgroundColor="#1E1833"
						Width="44" Height="40"
						TextHorizontalAlignment="Center" TextVerticalAlignment="Center"/>
					<Node2D Name="CardTextSpacer" Height="8"/>
					<TextBlock Name="CardTextTitle" Text="Text Rendering" FontSize="16" ForegroundColor="#F1F5F9"/>
					<TextBlock Name="CardTextBody"
						Text="Pixel-perfect typography with kerning, multi-language support, and full font control."
						FontSize="13" ForegroundColor="#4B5563" WordWrap="true"/>
				</StackView>
				<StackView Name="CardLayout" Direction="Vertical" Spacing="10" BackgroundColor="#141420" Padding="28">
					<TextBlock Name="CardLayoutIcon" Text="#" FontSize="22" ForegroundColor="#10B981" BackgroundColor="#0D2020"
						Width="44" Height="40"
						TextHorizontalAlignment="Center" TextVerticalAlignment="Center"/>
					<Node2D Name="CardLayoutSpacer" Height="8"/>
					<TextBlock Name="CardLayoutTitle" Text="Flexible Layouts" FontSize="16" ForegroundColor="#F1F5F9"/>
					<TextBlock Name="CardLayoutBody"
						Text="Grid and stack containers that adapt to any resolution, defined declaratively in XML."
						FontSize="13" ForegroundColor="#4B5563" WordWrap="true"/>
				</StackView>
				<StackView Name="CardImage" Direction="Vertical" Spacing="10" BackgroundColor="#141420" Padding="28">
					<ImageView Name="CardImageThumb" Image="Example/Images/dog" Width="200" Height="80"/>
					<TextBlock Name="CardImageTitle" Text="Image Integration" FontSize="16" ForegroundColor="#F1F5F9"/>
					<TextBlock Name="CardImageBody"
						Text="Fast texture loading with stretch, crop, and nine-patch rendering built in."
						FontSize="13" ForegroundColor="#4B5563" WordWrap="true"/>
				</StackView>
			</Grid>
			<StackView Name="GallerySection" Direction="Vertical" Spacing="20" BackgroundColor="#0B0B12" Padding="40">
				<Node.HorizontalPadding>IF(STEP(640, {../../Node.ActualWidth}), Vector2(40,40), Vector2(8,8))</Node.HorizontalPadding>
				<TextBlock Name="GalleryHeading" Text="Gallery" FontSize="28" ForegroundColor="#F1F5F9"/>
				<TextBlock Name="GallerySubheading"
					Text="Screenshots and scenes rendered entirely by the ORCA engine."
					FontSize="14" ForegroundColor="#64748B"/>
				<Grid Name="GalleryGrid" Columns="auto auto" Spacing="16">
					<StackView Name="GalleryCard1" Direction="Vertical" Spacing="0" BackgroundColor="#141420">
						<ImageView Name="GalleryImg1" Image="Example/Images/lake" Height="180" Stretch="UniformToFill"/>
						<StackView Name="GalleryCard1Caption" Direction="Vertical" Spacing="4" Padding="16">
							<TextBlock Name="GalleryCard1Title" Text="Lake Scene" FontSize="15" ForegroundColor="#F1F5F9"/>
							<TextBlock Name="GalleryCard1Body" Text="Real-time reflections and water surface rendered at 60 fps."
								FontSize="12" ForegroundColor="#4B5563" WordWrap="true"/>
						</StackView>
					</StackView>
					<StackView Name="GalleryCard2" Direction="Vertical" Spacing="0" BackgroundColor="#141420">
						<ImageView Name="GalleryImg2" Image="Example/Images/peacock" Height="180" Stretch="UniformToFill"/>
						<StackView Name="GalleryCard2Caption" Direction="Vertical" Spacing="4" Padding="16">
							<TextBlock Name="GalleryCard2Title" Text="Peacock" FontSize="15" ForegroundColor="#F1F5F9"/>
							<TextBlock Name="GalleryCard2Body" Text="High-fidelity texture sampling with anisotropic filtering."
								FontSize="12" ForegroundColor="#4B5563" WordWrap="true"/>
						</StackView>
					</StackView>
				</Grid>
			</StackView>
			<StackView Name="WorkflowSection" Direction="Vertical" Spacing="24" BackgroundColor="#09090F" Padding="40">
				<Node.HorizontalPadding>IF(STEP(640, {../../Node.ActualWidth}), Vector2(40,40), Vector2(8,8))</Node.HorizontalPadding>
				<TextBlock Name="WorkflowHeading" Text="How It Works" FontSize="28" ForegroundColor="#F1F5F9"/>
				<TextBlock Name="WorkflowSubheading"
					Text="From XML layout to a live rendered scene in four simple steps."
					FontSize="14" ForegroundColor="#64748B"/>
				<Grid Name="WorkflowSteps" Columns="auto auto auto auto" Spacing="16">
					<Grid.Columns>IF(STEP(640, {../../../Node.ActualWidth}), "auto auto auto auto", "auto auto")</Grid.Columns>
					<Grid.Rows>IF(STEP(640, {../../../Node.ActualWidth}), "auto", "auto auto")</Grid.Rows>
					<StackView Name="Step1" Direction="Vertical" Spacing="12" BackgroundColor="#141420" Padding="24">
						<TextBlock Name="Step1Number" Text="01" FontSize="32" ForegroundColor="#8B5CF6"/>
						<TextBlock Name="Step1Title" Text="Define Layout" FontSize="15" ForegroundColor="#F1F5F9"/>
						<TextBlock Name="Step1Body" Text="Write your screen as an XML file with familiar Grid and StackView containers."
							FontSize="12" ForegroundColor="#4B5563" WordWrap="true"/>
					</StackView>
					<StackView Name="Step2" Direction="Vertical" Spacing="12" BackgroundColor="#141420" Padding="24">
						<TextBlock Name="Step2Number" Text="02" FontSize="32" ForegroundColor="#3B82F6"/>
						<TextBlock Name="Step2Title" Text="Load Assets" FontSize="15" ForegroundColor="#F1F5F9"/>
						<TextBlock Name="Step2Body" Text="Images, fonts, and data files are streamed from packages at runtime."
							FontSize="12" ForegroundColor="#4B5563" WordWrap="true"/>
					</StackView>
					<StackView Name="Step3" Direction="Vertical" Spacing="12" BackgroundColor="#141420" Padding="24">
						<TextBlock Name="Step3Number" Text="03" FontSize="32" ForegroundColor="#10B981"/>
						<TextBlock Name="Step3Title" Text="Script Logic" FontSize="15" ForegroundColor="#F1F5F9"/>
						<TextBlock Name="Step3Body" Text="Attach Lua scripts to any component for interactivity and data binding."
							FontSize="12" ForegroundColor="#4B5563" WordWrap="true"/>
					</StackView>
					<StackView Name="Step4" Direction="Vertical" Spacing="12" BackgroundColor="#141420" Padding="24">
						<TextBlock Name="Step4Number" Text="04" FontSize="32" ForegroundColor="#F59E0B"/>
						<TextBlock Name="Step4Title" Text="Ship" FontSize="15" ForegroundColor="#F1F5F9"/>
						<TextBlock Name="Step4Body" Text="Deploy to desktop, mobile, or WebGL with a single build command."
							FontSize="12" ForegroundColor="#4B5563" WordWrap="true"/>
					</StackView>
				</Grid>
			</StackView>
			<StackView Name="TestimonialsSection" Direction="Vertical" Spacing="24" BackgroundColor="#0B0B12" Padding="40">
				<Node.HorizontalPadding>IF(STEP(640, {../../Node.ActualWidth}), Vector2(40,40), Vector2(8,8))</Node.HorizontalPadding>
				<TextBlock Name="TestimonialsHeading" Text="What Developers Say" FontSize="28" ForegroundColor="#F1F5F9"/>
				<Grid Name="TestimonialsGrid" Columns="auto auto auto" Spacing="20">
					<StackView Name="Quote1" Direction="Vertical" Spacing="16" BackgroundColor="#141420" Padding="28">
						<TextBlock Name="Quote1Mark" Text="&#x201C;" FontSize="48" ForegroundColor="#8B5CF6"/>
						<TextBlock Name="Quote1Text"
							Text="ORCA lets us ship native-quality UI on every platform from a single XML source. It changed how we build products."
							FontSize="13" ForegroundColor="#94A3B8" WordWrap="true"/>
						<StackView Name="Quote1Author" Direction="Horizontal" Spacing="12" AlignItems="Center">
							<TextBlock Name="Quote1AuthorName" Text="— Alex R." FontSize="13" ForegroundColor="#F1F5F9"/>
							<TextBlock Name="Quote1AuthorRole" Text="Lead Engineer" FontSize="11" ForegroundColor="#4B5563"/>
						</StackView>
					</StackView>
					<StackView Name="Quote2" Direction="Vertical" Spacing="16" BackgroundColor="#141420" Padding="28">
						<TextBlock Name="Quote2Mark" Text="&#x201C;" FontSize="48" ForegroundColor="#10B981"/>
						<TextBlock Name="Quote2Text"
							Text="The declarative layout system is a joy to work with. Our designers write XML and developers hook up the logic — perfect split."
							FontSize="13" ForegroundColor="#94A3B8" WordWrap="true"/>
						<StackView Name="Quote2Author" Direction="Horizontal" Spacing="12" AlignItems="Center">
							<TextBlock Name="Quote2AuthorName" Text="— Sam T." FontSize="13" ForegroundColor="#F1F5F9"/>
							<TextBlock Name="Quote2AuthorRole" Text="UI Architect" FontSize="11" ForegroundColor="#4B5563"/>
						</StackView>
					</StackView>
					<StackView Name="Quote3" Direction="Vertical" Spacing="16" BackgroundColor="#141420" Padding="28">
						<TextBlock Name="Quote3Mark" Text="&#x201C;" FontSize="48" ForegroundColor="#3B82F6"/>
						<TextBlock Name="Quote3Text"
							Text="Sub-millisecond frame times even on mid-range hardware. We ditched our old HTML renderer the day we tried ORCA."
							FontSize="13" ForegroundColor="#94A3B8" WordWrap="true"/>
						<StackView Name="Quote3Author" Direction="Horizontal" Spacing="12" AlignItems="Center">
							<TextBlock Name="Quote3AuthorName" Text="— Jordan M." FontSize="13" ForegroundColor="#F1F5F9"/>
							<TextBlock Name="Quote3AuthorRole" Text="Game Developer" FontSize="11" ForegroundColor="#4B5563"/>
						</StackView>
					</StackView>
				</Grid>
			</StackView>
			<StackView Name="CtaSection" Direction="Vertical" Spacing="24" BackgroundColor="#1A1A28" Padding="60" AlignItems="Center">
				<Node.HorizontalPadding>IF(STEP(640, {../../Node.ActualWidth}), Vector2(60,60), Vector2(16,16))</Node.HorizontalPadding>
				<TextBlock Name="CtaHeading" Text="Ready to build something great?" FontSize="36" ForegroundColor="#F1F5F9" TextHorizontalAlignment="Center"/>
				<TextBlock Name="CtaBody"
					Text="Download ORCA, open a sample project, and have your first screen running in minutes."
					FontSize="15" ForegroundColor="#64748B" WordWrap="true" TextHorizontalAlignment="Center"/>
				<StackView Name="CtaButtons" Direction="Horizontal" Spacing="16">
					<TextBlock Name="CtaButtonPrimary" Text="Get Started" FontSize="14" ForegroundColor="#FFFFFF"
						BackgroundColor="#8B5CF6" Padding="16" Width="140" Height="44"
						TextHorizontalAlignment="Center" TextVerticalAlignment="Center"/>
					<TextBlock Name="CtaButtonSecondary" Text="View on GitHub" FontSize="14" ForegroundColor="#94A3B8"
						BackgroundColor="#141420" Padding="16" Width="140" Height="44"
						TextHorizontalAlignment="Center" TextVerticalAlignment="Center"/>
				</StackView>
			</StackView>
		</StackView>
	</Grid>
</Screen>