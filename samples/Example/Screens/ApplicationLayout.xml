<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE Screen SYSTEM "https://corepunch.github.io/orca/schemas/orca.dtd">
<Screen Name="Application" ResizeMode="CanResize" ClearColor="#0B0B12">

  <!-- ================================================================ -->
  <!-- LANDSCAPE LAYOUT  (width > height)                               -->
  <!-- ================================================================ -->
  <Grid Name="LandscapeRoot" Rows="64px 360px auto auto" Spacing="0">

    <Node2D Name="NavBar" BackgroundColor="#11111C">
      <StackView Name="NavLinks" Direction="Horizontal" Spacing="32" AlignItems="Center" Margin="40">
        <TextBlock Name="Brand"       Text="ORCA"     FontSize="20" ForegroundColor="#8B5CF6" Width="72"/>
        <TextBlock Name="NavOverview" Text="Overview" FontSize="14" ForegroundColor="#94A3B8"/>
        <TextBlock Name="NavFeatures" Text="Features" FontSize="14" ForegroundColor="#94A3B8"/>
        <TextBlock Name="NavGallery"  Text="Gallery"  FontSize="14" ForegroundColor="#94A3B8"/>
        <TextBlock Name="NavDocs"     Text="Docs"     FontSize="14" ForegroundColor="#94A3B8"/>
      </StackView>
    </Node2D>

    <Grid Name="Hero" Columns="1fr 1fr" Spacing="24" BackgroundColor="#0B0B12">
      <Node2D Name="HeroContent" Padding="56">
        <StackView Name="HeroStack" Direction="Vertical" Spacing="0">
          <TextBlock Name="HeadlineLine1" Text="Build stunning"   FontSize="48" ForegroundColor="#F1F5F9"/>
          <TextBlock Name="HeadlineLine2" Text="UI in real-time." FontSize="48" ForegroundColor="#8B5CF6"/>
          <Node2D Name="HeadlineSpacer" Height="20"/>
          <TextBlock Name="SubHeadline"
            Text="A modern UI engine for games and native apps. Compose layouts from grids, stacks, text, and images — all rendered at 60 fps."
            FontSize="15"
            ForegroundColor="#64748B"
            WordWrap="true"/>
          <Node2D Name="MetricSpacer" Height="40"/>
          <Grid Name="Metrics" Columns="1fr 1fr 1fr" Spacing="16">
            <Node2D Name="MetricUsers" BackgroundColor="#1A1A28" Padding="20">
              <StackView Direction="Vertical" Spacing="4">
                <TextBlock Name="MetricUsersValue" Text="2.4 M"       FontSize="28" ForegroundColor="#8B5CF6"/>
                <TextBlock Name="MetricUsersLabel" Text="Active users" FontSize="11" ForegroundColor="#4B5563"/>
              </StackView>
            </Node2D>
            <Node2D Name="MetricUptime" BackgroundColor="#1A1A28" Padding="20">
              <StackView Direction="Vertical" Spacing="4">
                <TextBlock Name="MetricUptimeValue" Text="99.9 %"    FontSize="28" ForegroundColor="#10B981"/>
                <TextBlock Name="MetricUptimeLabel" Text="Uptime SLA" FontSize="11" ForegroundColor="#4B5563"/>
              </StackView>
            </Node2D>
            <Node2D Name="MetricFrame" BackgroundColor="#1A1A28" Padding="20">
              <StackView Direction="Vertical" Spacing="4">
                <TextBlock Name="MetricFrameValue" Text="1.2 ms"    FontSize="28" ForegroundColor="#3B82F6"/>
                <TextBlock Name="MetricFrameLabel" Text="Frame time" FontSize="11" ForegroundColor="#4B5563"/>
              </StackView>
            </Node2D>
          </Grid>
        </StackView>
      </Node2D>
      <ImageView Name="HeroImage" Image="Example/Images/people" Stretch="UniformToFill" MarginRight="56" MarginTop="16"/>
    </Grid>

    <Node2D Name="FeatureSection" BackgroundColor="#09090F" Padding="40">
      <Grid Name="FeatureCards" Columns="1fr 1fr 1fr" Spacing="20">

        <Node2D Name="CardText" BackgroundColor="#141420" Padding="28">
          <StackView Name="CardTextStack" Direction="Vertical" Spacing="10" AlignItems="Stretch">
            <TextBlock Name="CardTextIcon"  Text="Aa" FontSize="20" ForegroundColor="#8B5CF6" BackgroundColor="#1E1833"
                       Width="44" Height="40"
                       TextHorizontalAlignment="Center" TextVerticalAlignment="Center"/>
            <Node2D Name="CardTextSpacer" Height="8"/>
            <TextBlock Name="CardTextTitle" Text="Text Rendering" FontSize="16" ForegroundColor="#F1F5F9"/>
            <TextBlock Name="CardTextBody"
              Text="Pixel-perfect typography with kerning, multi-language support, and full font control."
              FontSize="13" ForegroundColor="#4B5563" WordWrap="true"/>
          </StackView>
        </Node2D>

        <Node2D Name="CardLayout" BackgroundColor="#141420" Padding="28">
          <StackView Name="CardLayoutStack" Direction="Vertical" Spacing="10" AlignItems="Stretch">
            <TextBlock Name="CardLayoutIcon"  Text="#" FontSize="22" ForegroundColor="#10B981" BackgroundColor="#0D2020"
                       Width="44" Height="40"
                       TextHorizontalAlignment="Center" TextVerticalAlignment="Center"/>
            <Node2D Name="CardLayoutSpacer" Height="8"/>
            <TextBlock Name="CardLayoutTitle" Text="Flexible Layouts" FontSize="16" ForegroundColor="#F1F5F9"/>
            <TextBlock Name="CardLayoutBody"
              Text="Grid and stack containers that adapt to any resolution, defined declaratively in XML."
              FontSize="13" ForegroundColor="#4B5563" WordWrap="true"/>
          </StackView>
        </Node2D>

        <Node2D Name="CardImage" BackgroundColor="#141420" Padding="28">
          <StackView Name="CardImageStack" Direction="Vertical" Spacing="10" AlignItems="Stretch">
            <ImageView Name="CardImageThumb" Image="Example/Images/butterfly" Height="80" Stretch="UniformToFill"/>
            <TextBlock Name="CardImageTitle" Text="Image Integration" FontSize="16" ForegroundColor="#F1F5F9"/>
            <TextBlock Name="CardImageBody"
              Text="Fast texture loading with stretch, crop, and nine-patch rendering built in."
              FontSize="13" ForegroundColor="#4B5563" WordWrap="true"/>
          </StackView>
        </Node2D>

      </Grid>
    </Node2D>

    <Node2D Name="GallerySection" BackgroundColor="#0B0B12" Padding="40">
      <StackView Name="GalleryStack" Direction="Vertical" Spacing="20" AlignItems="Stretch">
        <TextBlock Name="GalleryTitle" Text="Gallery" FontSize="22" ForegroundColor="#F1F5F9"/>
        <Grid Name="GalleryGrid" Columns="1fr 1fr 1fr" Spacing="12">
          <ImageView Name="GalleryLake"    Image="Example/Images/lake"    Height="160" Stretch="UniformToFill"/>
          <ImageView Name="GalleryLaptop"  Image="Example/Images/laptop"  Height="160" Stretch="UniformToFill"/>
          <ImageView Name="GalleryPeacock" Image="Example/Images/peacock" Height="160" Stretch="UniformToFill"/>
        </Grid>
      </StackView>
    </Node2D>

  </Grid>

  <!-- ================================================================ -->
  <!-- PORTRAIT LAYOUT  (height > width)                                -->
  <!-- ================================================================ -->
  <Grid Name="PortraitRoot" Rows="56px auto auto auto" Spacing="0" Visible="false">

    <Node2D Name="PNavBar" BackgroundColor="#11111C">
      <StackView Name="PNavLinks" Direction="Horizontal" Spacing="20" AlignItems="Center" Margin="16">
        <TextBlock Name="PBrand"       Text="ORCA"     FontSize="18" ForegroundColor="#8B5CF6"/>
        <TextBlock Name="PNavFeatures" Text="Features" FontSize="13" ForegroundColor="#94A3B8"/>
        <TextBlock Name="PNavGallery"  Text="Gallery"  FontSize="13" ForegroundColor="#94A3B8"/>
        <TextBlock Name="PNavDocs"     Text="Docs"     FontSize="13" ForegroundColor="#94A3B8"/>
      </StackView>
    </Node2D>

    <!-- Hero: image on top, content below -->
    <Node2D Name="PHero" BackgroundColor="#0B0B12" Padding="20">
      <StackView Name="PHeroStack" Direction="Vertical" Spacing="16" AlignItems="Stretch">
        <ImageView Name="PHeroImage" Image="Example/Images/people" Height="200" Stretch="UniformToFill"/>
        <TextBlock Name="PHeadlineLine1" Text="Build stunning"   FontSize="36" ForegroundColor="#F1F5F9"/>
        <TextBlock Name="PHeadlineLine2" Text="UI in real-time." FontSize="36" ForegroundColor="#8B5CF6"/>
        <TextBlock Name="PSubHeadline"
          Text="A modern UI engine for games and native apps."
          FontSize="14"
          ForegroundColor="#64748B"
          WordWrap="true"/>
        <Grid Name="PMetrics" Columns="1fr 1fr" Spacing="12">
          <Node2D Name="PMetricUsers" BackgroundColor="#1A1A28" Padding="16">
            <StackView Direction="Vertical" Spacing="4">
              <TextBlock Name="PMetricUsersValue" Text="2.4 M"       FontSize="22" ForegroundColor="#8B5CF6"/>
              <TextBlock Name="PMetricUsersLabel" Text="Active users" FontSize="11" ForegroundColor="#4B5563"/>
            </StackView>
          </Node2D>
          <Node2D Name="PMetricUptime" BackgroundColor="#1A1A28" Padding="16">
            <StackView Direction="Vertical" Spacing="4">
              <TextBlock Name="PMetricUptimeValue" Text="99.9 %"    FontSize="22" ForegroundColor="#10B981"/>
              <TextBlock Name="PMetricUptimeLabel" Text="Uptime SLA" FontSize="11" ForegroundColor="#4B5563"/>
            </StackView>
          </Node2D>
        </Grid>
      </StackView>
    </Node2D>

    <!-- Features: single column -->
    <Node2D Name="PFeatureSection" BackgroundColor="#09090F" Padding="20">
      <StackView Name="PFeatureCards" Direction="Vertical" Spacing="16" AlignItems="Stretch">

        <Node2D Name="PCardText" BackgroundColor="#141420" Padding="20">
          <StackView Direction="Vertical" Spacing="8" AlignItems="Stretch">
            <TextBlock Name="PCardTextIcon"  Text="Aa" FontSize="18" ForegroundColor="#8B5CF6" BackgroundColor="#1E1833"
                       Width="40" Height="36"
                       TextHorizontalAlignment="Center" TextVerticalAlignment="Center"/>
            <TextBlock Name="PCardTextTitle" Text="Text Rendering" FontSize="15" ForegroundColor="#F1F5F9"/>
            <TextBlock Name="PCardTextBody"
              Text="Pixel-perfect typography with kerning, multi-language support, and full font control."
              FontSize="13" ForegroundColor="#4B5563" WordWrap="true"/>
          </StackView>
        </Node2D>

        <Node2D Name="PCardLayout" BackgroundColor="#141420" Padding="20">
          <StackView Direction="Vertical" Spacing="8" AlignItems="Stretch">
            <TextBlock Name="PCardLayoutIcon"  Text="#" FontSize="20" ForegroundColor="#10B981" BackgroundColor="#0D2020"
                       Width="40" Height="36"
                       TextHorizontalAlignment="Center" TextVerticalAlignment="Center"/>
            <TextBlock Name="PCardLayoutTitle" Text="Flexible Layouts" FontSize="15" ForegroundColor="#F1F5F9"/>
            <TextBlock Name="PCardLayoutBody"
              Text="Grid and stack containers that adapt to any resolution, defined declaratively in XML."
              FontSize="13" ForegroundColor="#4B5563" WordWrap="true"/>
          </StackView>
        </Node2D>

        <Node2D Name="PCardImage" BackgroundColor="#141420" Padding="20">
          <StackView Direction="Vertical" Spacing="8" AlignItems="Stretch">
            <ImageView Name="PCardImageThumb" Image="Example/Images/butterfly" Height="100" Stretch="UniformToFill"/>
            <TextBlock Name="PCardImageTitle" Text="Image Integration" FontSize="15" ForegroundColor="#F1F5F9"/>
            <TextBlock Name="PCardImageBody"
              Text="Fast texture loading with stretch, crop, and nine-patch rendering built in."
              FontSize="13" ForegroundColor="#4B5563" WordWrap="true"/>
          </StackView>
        </Node2D>

      </StackView>
    </Node2D>

    <!-- Gallery: 2-column grid for portrait -->
    <Node2D Name="PGallerySection" BackgroundColor="#0B0B12" Padding="20">
      <StackView Name="PGalleryStack" Direction="Vertical" Spacing="16" AlignItems="Stretch">
        <TextBlock Name="PGalleryTitle" Text="Gallery" FontSize="20" ForegroundColor="#F1F5F9"/>
        <Grid Name="PGalleryGrid" Columns="1fr 1fr" Spacing="8">
          <ImageView Name="PGalleryLake"    Image="Example/Images/lake"      Height="120" Stretch="UniformToFill"/>
          <ImageView Name="PGalleryLaptop"  Image="Example/Images/laptop"    Height="120" Stretch="UniformToFill"/>
          <ImageView Name="PGalleryPeacock" Image="Example/Images/peacock"   Height="120" Stretch="UniformToFill"/>
          <ImageView Name="PGalleryPeople"  Image="Example/Images/butterfly" Height="120" Stretch="UniformToFill"/>
        </Grid>
      </StackView>
    </Node2D>

  </Grid>

</Screen>
