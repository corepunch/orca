<?xml version="1.0"?>
<Project Name="Example" StartupScreen="Example/Screens/Application">
  <ScreenLibrary Name="Screens" IsExternal="true"/>
  <ImageLibrary Name="Images" IsExternal="true"/>
  <Project.PropertyTypes>
    <PropertyType Name="Speed" DataType="Float" Category="Custom"/>
  </Project.PropertyTypes>
  <Project.SystemMessages>
    <SystemMessage Message="KeyDown" Key="q" Command="return"/>
    <SystemMessage Message="WindowClosed" Command="return"/>
    <SystemMessage Message="RequestReload" Command="window:refresh()"/>
  </Project.SystemMessages>
</Project>
