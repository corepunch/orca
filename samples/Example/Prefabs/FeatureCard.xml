<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE StackView SYSTEM "https://corepunch.github.io/orca/schemas/orca.dtd">
<StackView Name="FeatureCard" class="card stack-card feature-card">
	<TextBlock Name="FeatureCardIcon" class="feature-card-icon"
		Text="{Binding ../Card.Icon}" ForegroundColor="{Binding ../Card.PrimaryColor}" BackgroundColor="{Binding ../Card.IconBackground}"/>
	<Node2D Name="FeatureCardSpacer" class="feature-card-spacer"/>
	<TextBlock Name="FeatureCardTitle" class="card-title" Text="{Binding ../Card.Title}"/>
	<TextBlock Name="FeatureCardBody" class="card-body" Text="{Binding ../Card.Body}"/>
</StackView>
