<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE StackView SYSTEM "https://corepunch.github.io/orca/schemas/orca.dtd">
<StackView Name="SignalCard" class="card signal-card">
	<ImageView Name="SignalCardIcon" class="signal-icon" Source="{Binding Card.Icon}" ForegroundColor="{Binding Card.PrimaryColor}"/>
	<StackView Name="SignalCardCopy" class="signal-copy">
		<TextBlock Name="SignalCardTitle" class="signal-title" Text="{Binding Card.Title}"/>
		<TextBlock Name="SignalCardBody" class="signal-body" Text="{Binding Card.Body}"/>
	</StackView>
</StackView>
