<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE StackView SYSTEM "https://corepunch.github.io/orca/schemas/orca.dtd">
<StackView Name="WorkflowStep" class="card workflow-step">
	<TextBlock Name="WorkflowStepNumber" class="workflow-number" Text="{Binding ../Card.Title}" ForegroundColor="{Binding ../Card.PrimaryColor}"/>
	<TextBlock Name="WorkflowStepTitle" class="workflow-title" Text="{Binding ../Card.Subtitle}"/>
	<TextBlock Name="WorkflowStepBody" class="card-body" Text="{Binding ../Card.Body}"/>
</StackView>
