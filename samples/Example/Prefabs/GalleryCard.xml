<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE StackView SYSTEM "https://corepunch.github.io/orca/schemas/orca.dtd">
<StackView Name="GalleryCard" Direction="Vertical" Spacing="0" BackgroundColor="card-background">
	<ImageView Name="GalleryCardImage" Height="180" Stretch="UniformToFill">
		<ImageView.Image>{../Card.Image}</ImageView.Image>
	</ImageView>
	<StackView Name="GalleryCardCaption" Direction="Vertical" Spacing="4" Padding="16">
		<TextBlock Name="GalleryCardTitle" FontSize="15" ForegroundColor="text-primary">
			<TextRun.Text>{../../Card.Title}</TextRun.Text>
		</TextBlock>
		<TextBlock Name="GalleryCardBody" FontSize="12" ForegroundColor="text-dim" WordWrap="true">
			<TextRun.Text>{../../Card.Subtitle}</TextRun.Text>
		</TextBlock>
	</StackView>
</StackView>
