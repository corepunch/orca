<?xml version="1.0" encoding="utf-8"?>
<StackView Name="GetStartedPopup" Direction="Vertical" Spacing="14" Width="420" BackgroundColor="$surface-deep" Padding="24" Visible="FALSE">
  <TextBlock Name="GetStartedPopupTitle" Text="What ORCA gives you" FontSize="20" ForegroundColor="$text-primary"/>
