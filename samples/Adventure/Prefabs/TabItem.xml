<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE StackView SYSTEM "https://corepunch.github.io/orca/schemas/orca.dtd">
<StackView Name="TabItem" class="tab-item">
	<ImageView Name="TabItemIcon" class="tab-icon" Source="{Binding DataContext/Icon}"/>
	<TextBlock Name="TabItemLabel" class="tab-label" Text="{Binding DataContext/Label}"/>
</StackView>
