<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE Screen SYSTEM "https://corepunch.github.io/orca/schemas/orca.dtd">
<Screen Name="Adventures" Width="400" Height="800" ClearColor="$background" StyleSheet="Adventure/Styles/app.css">
	<Grid Name="Root" Rows="32px 52px 1fr 72px 24px" class="page">
		<Node2D class="header"/>
		<StackView Name="Header" class="header">
			<TextBlock Name="HeaderTitle" class="header-title">Chronicle</TextBlock>
			<TextBlock Name="HeaderSubtitle" class="header-subtitle">Choose an adventure</TextBlock>
		</StackView>
		<ListBox Name="GameList" class="game-list"
			ItemsSource="Adventure/Data/Games:Catalog"
			ItemTemplate="Adventure/Prefabs/GameCard"/>
		<ListBox Name="Footer" class="footer"
			ItemsSource="Adventure/Data/Tabs"
			ItemTemplate="Adventure/Prefabs/TabItem"/>
		<Node2D Name="FooterSpacer" class="footer"/>
	</Grid>
</Screen>
