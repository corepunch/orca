<?xml version="1.0"?>
<Project Name="Volcano" StartupScreen="Volcano/Screens/MainScreen">
  <ScreenLibrary Name="Screens" IsExternal="true"/>
  <ImageLibrary Name="Images" IsExternal="true"/>
  <Project.ProjectReferences>
    <ProjectReference Name="GameKit" Path="Scripts/GameKit"/>
    <ProjectReference Name="Scripts" Path="Scripts"/>
  </Project.ProjectReferences>
  <LibraryPlaceholder PlaceholderTemplate="Volcano/Sprites"/>
  <LibraryPlaceholder PlaceholderTemplate="Volcano/Sprite Animations"/>
  <Project.SystemMessages>
    <SystemMessage Message="KeyDown" Key="q" Command="return"/>
    <SystemMessage Message="WindowClosed" Command="return"/>
    <SystemMessage Message="RequestReload" Command="window:refresh()"/>
  </Project.SystemMessages>
</Project>
