#!/usr/bin/env python3
"""
ORCA code generation driver.

Usage: codegen <xml_file> <output_file|-> <mode>

  xml_file          Path to a module .xml file (e.g. source/core/core.xml)
  output_file|-     Destination file path, or - to write to stdout
  mode              One of: header | properties | export

Delegates to the pyphp templates in tools/templates/.
"""

import os
import subprocess
import sys

MODES = {
    "header":     "header.php",
    "properties": "properties.php",
    "export":     "export.php",
}


def main():
    if len(sys.argv) != 4:
        print(
            f"Usage: {os.path.basename(sys.argv[0])} <xml_file> <output_file|-> <mode>",
            file=sys.stderr,
        )
        sys.exit(1)

    xml_file, output, mode = sys.argv[1], sys.argv[2], sys.argv[3]

    if mode not in MODES:
        print(
            f"Unknown mode '{mode}'. Must be one of: {', '.join(MODES)}",
            file=sys.stderr,
        )
        sys.exit(1)

    tools_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    template = os.path.join(tools_dir, "templates", MODES[mode])

    result = subprocess.run(
        [sys.executable, "-m", "pyphp.pyphp", template, xml_file],
        capture_output=True,
        text=True,
    )

    if result.returncode != 0:
        sys.stderr.write(result.stderr)
        sys.exit(result.returncode)

    if output == "-":
        sys.stdout.write(result.stdout)
    else:
        os.makedirs(os.path.dirname(os.path.abspath(output)), exist_ok=True)
        with open(output, "w", encoding="utf-8") as fh:
            fh.write(result.stdout)


if __name__ == "__main__":
    main()
